{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ],
  "files": [
    "artifacts/**",
    "src/**",
    "contracts/**",
    "package.json",
    "package-lock.json"
  ]
}
